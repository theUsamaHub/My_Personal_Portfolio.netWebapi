# .env.example - Copy this to .env and fill in your values

# JWT Settings
JWT_KEY=your-super-secret-jwt-key-min-32-chars
JWT_ISSUER=MyPersonalPortfolio
JWT_AUDIENCE=MyPersonalPortfolioAdmin

# Admin User
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=YourStrongPassword123!@#
ADMIN_FULL_NAME=Administrator

# Secret Login Endpoint
SECRET_LOGIN_ENDPOINT=your-secret-endpoint-name

# Database (Optional - if you want to override appsettings)
# DB_CONNECTION_STRING=your-connection-string
